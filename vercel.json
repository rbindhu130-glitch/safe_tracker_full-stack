{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/api/index.py"
    },
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/(style|js|assets|pages)/(.*)",
      "destination": "/frontend/$1/$2"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}